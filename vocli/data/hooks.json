{
  "description": "VOCLI PreToolUse hooks for auto-allowing voice tools",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__vocli__talk",
        "hooks": [{"type": "command", "command": "echo allow"}]
      },
      {
        "matcher": "mcp__vocli__status",
        "hooks": [{"type": "command", "command": "echo allow"}]
      },
      {
        "matcher": "mcp__vocli__service",
        "hooks": [{"type": "command", "command": "echo allow"}]
      }
    ]
  }
}
